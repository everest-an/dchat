# ============================================
# Dchat Environment Variables
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env files with real credentials to Git!
# ============================================

# ============================================
# Go Backend Configuration (backend-go)
# ============================================

# Server
API_PORT=8080
WEBSOCKET_PORT=8081
ENVIRONMENT=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dchat_user
DB_PASSWORD=
DB_NAME=dchat_prod
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=
JWT_EXPIRATION_HOURS=24

# Web3 / Blockchain
RPC_URL=
CHAIN_ID=11155111
CONTRACT_ADDRESS=

# ============================================
# Python Backend Configuration (backend)
# ============================================

# Flask
SECRET_KEY=
FLASK_ENV=production

# Database
DATABASE_URL=

# Web3 Provider
WEB3_PROVIDER_URL=

# ============================================
# Pinata IPFS Configuration
# ============================================
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# ============================================
# Frontend Configuration (Vite env vars)
# ============================================

# API URLs
VITE_API_URL=
VITE_API_BASE_URL=
VITE_BACKEND_URL=
VITE_WS_URL=
VITE_SOCKET_URL=

# Blockchain
VITE_CHAIN_ID=11155111
VITE_NETWORK_NAME=sepolia
VITE_RPC_URL=

# Smart Contract Addresses
VITE_MESSAGE_STORAGE_ADDRESS=
VITE_PAYMENT_ESCROW_ADDRESS=
VITE_USER_IDENTITY_ADDRESS=
VITE_PROJECT_COLLABORATION_ADDRESS=
VITE_LIVING_PORTFOLIO_ADDRESS=
VITE_VERIFIED_CREDENTIALS_ADDRESS=

# WalletConnect
VITE_WALLETCONNECT_PROJECT_ID=

# Pinata (Frontend)
VITE_PINATA_API_KEY=
VITE_PINATA_API_SECRET=
VITE_PINATA_JWT=

# Feature Flags
VITE_ENABLE_LINKEDIN_AUTH=true
VITE_ENABLE_EMAIL_VERIFICATION=true
VITE_ENABLE_PROJECT_COLLABORATION=true

# ============================================
# Supabase Configuration (Optional)
# ============================================
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ============================================
# AWS Configuration (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ============================================
# Stripe Configuration (Optional)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# LinkedIn OAuth (Optional)
# ============================================
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ============================================
# LiveKit Configuration (Optional)
# ============================================
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ============================================
# Monitoring (Optional)
# ============================================
SENTRY_DSN=

# ============================================
# Test Configuration (Optional)
# ============================================
TEST_WALLET_ADDRESS=
TEST_WALLET_PRIVATE_KEY=
